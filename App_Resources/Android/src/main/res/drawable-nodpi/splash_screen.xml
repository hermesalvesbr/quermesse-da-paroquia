<layer-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="fill">

    <!-- Fundo: gradiente dourado radial da marca -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="520dp"
                android:centerX="0.5"
                android:centerY="0.42"
                android:startColor="#FFF8DE"
                android:endColor="#E8B230" />
        </shape>
    </item>

    <!-- Anel sutil atrás do logo — halo de luz -->
    <item
        android:width="200dp"
        android:height="200dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#20FFFFFF" />
        </shape>
    </item>

    <!-- Logo do app centralizado -->
    <item
        android:width="160dp"
        android:height="160dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:filter="true"
            android:src="@drawable/logo" />
    </item>

</layer-list>