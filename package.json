{
  "name": "pdv-app",
  "version": "1.5.0",
  "private": true,
  "main": "app/app.ts",
  "scripts": {
    "dev:android": "concurrently -k -n vite,ns \"bun run dev:server:android\" \"wait-on tcp:5173 && bun run android\"",
    "dev:server:android": "vite serve -- --env.android --env.hmr",
    "android": "ns debug android --no-hmr",
    "build:android": "ns build android",
    "apk:organize": "bun scripts/export-apk.mjs",
    "apk:build": "bun run build:android && bun run apk:organize",
    "release:github": "bun scripts/release-apk.mjs",
    "lint": "eslint app eslint.config.mjs",
    "lint:fix": "eslint app eslint.config.mjs --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "bun run lint && bun run typecheck && bun run test",
    "postinstall": "bun scripts/postinstall-patches.mjs"
  },
  "dependencies": {
    "@directus/sdk": "^21.1.0",
    "@nativescript/core": "~9.0.0",
    "@valor/nativescript-websockets": "^2.0.2",
    "nativescript-vue": "^3.0.0",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@nativescript/android": "9.0.2",
    "@nativescript/tailwind": "^4.0.0",
    "@nativescript/types": "~9.0.0",
    "@nativescript/vite": "^1.0.5",
    "@types/node": "^20.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.36.0",
    "eslint-plugin-format": "^1.4.0",
    "nativescript": "^9.0.3",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.8.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.0"
  }
}
